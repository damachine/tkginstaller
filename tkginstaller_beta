# --- Helpers ---

# Styled message helpers
msg() {
  gum style --foreground "$GUM_FG" "$*"
}

warn() {
  gum style --foreground "$GUM_WARN" "⚠  $*"
}

# Extract bare value from a config line (last match wins, strips quotes)
cfg_val() {
  grep "^${1}=" "${2}" 2>/dev/null |
    tail -1 |
    sed "s/^${1}=//;s/'//g;s/\"//g"
}

# Check installed packages; install missing via pacman --needed
ensure_packages() {
  local missing=()
  local pkg
  for pkg in "$@"; do
    pacman -Qq "$pkg" &>/dev/null || missing+=("$pkg")
  done
  if ((${#missing[@]} > 0)); then
    msg "Installing missing build dependencies: ${missing[*]}"
    sudo pacman -S --needed --asdeps --noconfirm "${missing[@]}" || return 1
  fi
}

# Git clone with retry (exponential backoff)
git_clone_retry() {
  local url="$1"
  local target="${2:-}"
  local max="${3:-3}"
  local attempt=0

  while ((attempt < max)); do
    if [[ -n "$target" ]]; then
      git clone "$url" "$target" && return 0
    else
      git clone "$url" && return 0
    fi
    ((attempt++))
    warn "Clone failed (attempt ${attempt}/${max}). Retrying in $((attempt * 2))s..."
    sleep $((attempt * 2))
  done
  return 1
}

# Fatal error — triggers cleanup via EXIT trap
die() {
  gum style --foreground "$GUM_ERR" "✗  $*" >&2
  exit 1
}

# Smart editor launcher — respects $EDITOR, falls back gracefully
open_editor() {
  local target="$1"
  local -a parts=()

  # Split $EDITOR into command + args
  if [[ -n "${EDITOR-}" ]]; then
    IFS=' ' read -r -a parts <<<"$EDITOR"
  fi

  # Fallback if $EDITOR not set or unavailable
  if [[ -z "${parts[0]:-}" ]] || ! command -v "${parts[0]}" &>/dev/null; then
    for ed in nano micro vim vi; do
      if command -v "$ed" &>/dev/null; then
        parts=("$ed")
        break
      fi
    done
  fi

  if [[ -z "${parts[0]:-}" ]]; then
    warn "No editor found. Set \$EDITOR or install nano/micro/vim."
    return 1
  fi

  "${parts[@]}" "$target"
}

# Show package info + config hints before install
show_pkg_info() {
  local pkg="$1"
  local label="${LABEL[$pkg]:-$pkg}"
  local cfg_url="${CFG[$pkg]:-}"

  echo
  gum style --foreground "$GUM_FG" --bold \
    "Configuration Options for ${label}"
  echo
  msg "A wide range of options are available!"
  msg "TkG packages can be precisely tailored to your system."
  echo
  msg "Set up customization.cfg using one of the following options:"
  echo
  gum style --foreground "$GUM_WARN" \
    "A │ tkginstaller → Config → ${label}   (interactive)"
  gum style --foreground "$GUM_WARN" \
    "B │ tkginstaller ${pkg} config           (direct)"
