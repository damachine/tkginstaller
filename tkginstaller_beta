# --- Core functions ---

# Ask upstream vs staging fork for linux or nvidia
pick_repo() {
  local pkg="$1"
  local upstream="${REPO[$pkg]}"
  local staging=""

  case "$pkg" in
    linux) staging="${STAGING_LINUX}" ;;
    nvidia) staging="${STAGING_NVIDIA}" ;;
    *)
      echo "$upstream"
      return
      ;;
  esac

  local choice
  choice=$(gum choose \
    --header "${LABEL[$pkg]} — which repository?" \
    --header.foreground "$GUM_FG" \
    --cursor.foreground "$GUM_FG" \
    "Upstream  (Frogging-Family)" \
    "Staging   (damachine fork)")

  case "$choice" in
    Staging*) echo "$staging" ;;
    *) echo "$upstream" ;;
  esac
}

fetch_repo() {
  local pkg="$1"
  local repo_url="${2:-${REPO[$pkg]}}"
  local dir="${CACHE}/${pkg}"

  mkdir -p "$CACHE"

  if [[ -d "${dir}/.git" ]]; then
    # Update existing clone; fall back to fresh clone on failure
    msg "Updating ${LABEL[$pkg]} (git pull)..."
    if ! git -C "$dir" pull --ff-only 2>/dev/null; then
      warn "Git pull failed, trying fresh clone..."
      rm -rf "$dir"
      git_clone_retry "$repo_url" "$dir" || die "Cloning failed for: ${LABEL[$pkg]}"
    fi
  elif [[ -d "$dir" ]]; then
    # Directory exists but without .git — handle immutable patches
    local has_immutable=false
    if command -v lsattr &>/dev/null; then
      while IFS= read -r -d '' chk; do
        if lsattr "$chk" 2>/dev/null | cut -d' ' -f1 | grep -qF 'i'; then
          has_immutable=true
          break
        fi
      done < <(find "$dir" -type f \( -name '*.myfrag' -o -name '*.mypatch' \) -print0 2>/dev/null)
    fi

    if [[ "$has_immutable" == "true" ]]; then
      msg "Immutable patch files detected — grafting .git..."
      local tmp_clone="${dir}.tkg_clone_$$"
      git_clone_retry "$repo_url" "$tmp_clone" || {
        rm -rf "$tmp_clone"
        die "Cloning failed for: ${LABEL[$pkg]}"
      }
      mv "$tmp_clone/.git" "$dir/.git"
      rm -rf "$tmp_clone"
      git -C "$dir" checkout -f HEAD 2>/dev/null
    else
      if gum confirm "Found '${pkg}' without git metadata. Remove and re-clone?"; then
        rm -rf "$dir"
        git_clone_retry "$repo_url" "$dir" || die "Cloning failed for: ${LABEL[$pkg]}"
      else
        die "Cannot continue without valid git repository."
      fi
    fi
  else
    # Fresh clone with retry
    msg "Cloning ${LABEL[$pkg]}..."
    git_clone_retry "$repo_url" "$dir" || die "Cloning failed for: ${LABEL[$pkg]}"
  fi

  # Display onefetch info if available
  if command -v onefetch &>/dev/null; then
    onefetch -C "$dir" --no-bold --no-title --no-art --no-color-palette \
      --http-url --nerd-fonts --text-colors 15 15 15 15 15 8 2>/dev/null |
      sed -u 's/^/ /'
  fi
}

copy_config() {
  local pkg="$1"
  local lcfg="${LOCAL[$pkg]:-}"
  [[ -z "$lcfg" ]] && return 0

  local src="${CFG_DIR}/${lcfg}"
  local dir="${CACHE}/${pkg}${SUBDIR[$pkg]:+/${SUBDIR[$pkg]}}"

  if [[ -f "$src" ]]; then
    cp "$src" "${dir}/"
    gum style --foreground "$GUM_FG" "✓  Using local config: ${lcfg}"
  fi
}

run_install() {
  local pkg="$1"
  local build_cmd="${2:-makepkg -si}"
  local skip_status="${3:-}"
  [[ -z "${REPO[$pkg]:-}" ]] && die "Unknown package: $pkg"

  show_pkg_info "$pkg"

  SECONDS=0
  local repo_url
  repo_url=$(pick_repo "$pkg")
  [[ -z "$repo_url" ]] && die "Cancelled."

  fetch_repo "$pkg" "$repo_url"
  local builddir="${CACHE}/${pkg}${SUBDIR[$pkg]:+/${SUBDIR[$pkg]}}"
  copy_config "$pkg"

  cd "$builddir"
  echo
  gum style --foreground "$GUM_FG" --bold "Building ${LABEL[$pkg]} ..."
  echo
  eval "$build_cmd"
  local rc=$?

  if [[ "$skip_status" != "1" ]]; then
    status "$rc" "${LABEL[$pkg]}"
  fi
  return "$rc"
}

# Linux-TKG install — build method choice based on distribution
run_linux() {
  local build_cmd
  if [[ "$IS_ARCH" == "true" ]]; then
    local method
    method=$(gum choose \
      --header "Linux-TKG — build method:" \
      --header.foreground "$GUM_FG" \
      --cursor.foreground "$GUM_FG" \
      "makepkg -si          (recommended for Arch)" \
      "install.sh install   (generic script)" \
      "install.sh uninstall-help" \
      "Cancel")

    case "$method" in
      makepkg*) build_cmd="makepkg -si" ;;
      *uninstall*) build_cmd="chmod +x install.sh && ./install.sh uninstall-help" ;;
      install*) build_cmd="chmod +x install.sh && ./install.sh install" ;;
      Cancel | "") return 1 ;;
    esac
  else
    local pkg_type=""
    case "${DISTRO_ID,,}" in
      debian | ubuntu | linuxmint | pop | elementary | mx | raspbian) pkg_type="DEB" ;;
      fedora | rhel | centos | rocky | alma | opensuse* | suse*) pkg_type="RPM" ;;
    esac
    [[ -n "$pkg_type" ]] && msg "${pkg_type}-based distribution detected: ${DISTRO_NAME}"
    build_cmd="chmod +x install.sh && ./install.sh install"
  fi

  run_install "linux" "$build_cmd"
  local rc=$?

  # Offer uninstall help for non-Arch
  if [[ "$IS_ARCH" != "true" && $rc -eq 0 ]]; then
    echo
    msg "Tip: Uninstalling custom kernels has to be done manually."
    if gum confirm "Show uninstall info now?"; then
      cd "${CACHE}/linux" && ./install.sh uninstall-help
    fi
  fi

  return "$rc"
}

