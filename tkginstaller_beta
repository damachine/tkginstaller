# Display build duration and result
status() {
  local code="${1:-0}"
  local label="${2:-}"
  local dur="${SECONDS:-0}"
  local min=$((dur / 60)) sec=$((dur % 60))

  echo
  gum style --foreground "$GUM_WARN" "Completed: $(date '+%Y-%m-%d %H:%M:%S')"
  if ((code == 0)); then
    msg "✓  ${label:+${label} — }Build successful"
  else
    gum style --foreground "$GUM_ERR" "✗  ${label:+${label} — }Failed (exit ${code})"
  fi
  gum style --foreground "$GUM_WARN" "Duration: ${min} min ${sec} sec"
}

# Cleanup handler — remove temps, unset globals
cleanup() {
  rm -f "${CACHE}/.choice.tmp" 2>/dev/null
  unset FROG FROG_RAW STAGING_LINUX STAGING_NVIDIA CACHE CFG_DIR \
    GUM_FG GUM_ERR GUM_WARN GUM_BORDER VERSION 2>/dev/null
}

# Central exit handler — always called via EXIT trap
on_exit() {
  local code=${1:-$?}
  trap - INT TERM EXIT HUP

  if ((code != 0 && code != 130)); then
    echo
    gum style --border rounded --border-foreground "$GUM_ERR" \
      --foreground "$GUM_ERR" --bold --padding "0 2" \
      "TKG-Installer — Error (exit ${code})"
    echo
    local dur="${SECONDS:-0}"
    gum style --foreground "$GUM_WARN" \
      "$(date '+%Y-%m-%d %H:%M:%S')  |  Duration: $((dur / 60)) min $((dur % 60)) sec"
    gum style --foreground "$GUM_ERR" \
      "Exiting due to errors. Check the messages above."
    echo
  elif ((code == 130)); then
    echo
    gum style --foreground "$GUM_WARN" "Interrupted by user."
  fi

  cleanup
  exit "$code"
}

# Wire traps — signals route through on_exit
trap 'trap - INT TERM EXIT HUP; on_exit 130' INT TERM HUP
trap 'on_exit $?' EXIT

