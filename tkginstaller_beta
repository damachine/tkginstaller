  case "${1,,}" in
    linux | l) echo "linux" ;;
    nvidia | n) echo "nvidia" ;;
    linux-nvidia | ln) echo "linux-nvidia" ;;
    mesa | m) echo "mesa" ;;
    wine | w) echo "wine" ;;
    proton | p) echo "proton" ;;
    dxvk | d) echo "dxvk" ;;
    vkd3d | v | vkd3d-proton) echo "vkd3d" ;;
    gamescope | g) echo "gamescope" ;;
