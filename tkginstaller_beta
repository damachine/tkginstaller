# Clean temporary files and cache (migrated from __clean_temp_dir)
clean_cache() {
  header
  msg "Cleaning all temporary files..."
  echo
  gum style --foreground "$GUM_WARN" "Location: ${CACHE}"
  echo

  # Read kernel work/source folders from linux-tkg.cfg
  local ltkg_cfg="${CFG_DIR}/linux-tkg.cfg"
  local kwf="" ksf=""
  if [[ -f "$ltkg_cfg" ]]; then
    kwf=$(grep '^_kernel_work_folder=' "$ltkg_cfg" 2>/dev/null | tail -1 | sed "s/^_kernel_work_folder=//;s/'//g;s/\"//g")
    ksf=$(grep '^_kernel_source_folder=' "$ltkg_cfg" 2>/dev/null | tail -1 | sed "s/^_kernel_source_folder=//;s/'//g;s/\"//g")
    kwf="${kwf/#\~/${HOME}}"
    ksf="${ksf/#\~/${HOME}}"
  fi

  # Collect all target directories for measurement
  local -a targets=()
  [[ -d "$CACHE" ]] && targets+=("$CACHE")
  for d in /tmp/makepkg/linux-tkg /tmp/makepkg/nvidia-all /tmp/makepkg/nvidia-*-tkg; do
    [[ -d "$d" ]] && targets+=("$d")
  done
  [[ -n "$kwf" && -d "${kwf}/linux-tkg" ]] && targets+=("${kwf}/linux-tkg")
  [[ -n "$ksf" && -d "${ksf}/linux-tkg" ]] && targets+=("${ksf}/linux-tkg")

  # Measure total files and bytes before deletion
  local file_count=0 total_bytes=0
  for d in "${targets[@]}"; do
    local cnt sz
    cnt=$(find "$d" -type f 2>/dev/null | wc -l || echo 0)
    sz=$(du -sb "$d" 2>/dev/null | cut -f1 || echo 0)
    ((file_count += cnt))
    ((total_bytes += sz))
  done

  # Human-readable size
  local size_human
  if ((total_bytes >= 1073741824)); then
    size_human="$(awk "BEGIN{printf \"%.1fG\", ${total_bytes}/1073741824}")"
  elif ((total_bytes >= 1048576)); then
    size_human="$(awk "BEGIN{printf \"%.1fM\", ${total_bytes}/1048576}")"
  elif ((total_bytes >= 1024)); then
    size_human="$(awk "BEGIN{printf \"%.1fK\", ${total_bytes}/1024}")"
  else
    size_human="${total_bytes}B"
  fi

  # Detect immutable patch files (chattr +i)
  local -a immutable=()
  if [[ -d "$CACHE" ]] && command -v lsattr &>/dev/null; then
    while IFS= read -r -d '' f; do
      if lsattr "$f" 2>/dev/null | cut -d' ' -f1 | grep -qF 'i'; then
        immutable+=("${f#"${CACHE}/"}")
      fi
    done < <(find "$CACHE" -type f \( -name '*.myfrag' -o -name '*.mypatch' \) -print0 2>/dev/null)
  fi

  if ((${#immutable[@]} > 0)); then
    warn "Keeping ${#immutable[@]} immutable patch file(s) (chattr +i):"
    for rel in "${immutable[@]}"; do
      gum style --foreground "$GUM_WARN" "  $rel"
    done
    gum style --foreground "$GUM_WARN" "  Revert with: chattr -i <file>"
    echo
  fi

  # Remove cache directory
  if [[ -d "$CACHE" ]]; then
    msg "Removing: ${CACHE}"
    rm -rf "$CACHE" 2>/dev/null
  fi

  # Remove /tmp/makepkg build dirs
  for d in /tmp/makepkg/linux-tkg /tmp/makepkg/nvidia-all /tmp/makepkg/nvidia-*-tkg; do
    [[ -d "$d" ]] || continue
    msg "Removing: ${d}"
    rm -rf "$d" 2>/dev/null
  done

  # Remove kernel work/source folders
  if [[ -n "$kwf" && -d "${kwf}/linux-tkg" ]]; then
    msg "Removing: ${kwf}/linux-tkg (_kernel_work_folder)"
    rm -rf "${kwf}/linux-tkg" 2>/dev/null
  fi
  if [[ -n "$ksf" && -d "${ksf}/linux-tkg" ]]; then
    msg "Removing: ${ksf}/linux-tkg (_kernel_source_folder)"
    rm -rf "${ksf}/linux-tkg" 2>/dev/null
  fi

  # Summary
  local removed=$((file_count - ${#immutable[@]}))
  echo
  if ((removed <= 0)); then
    msg "✓  Cleanup complete (cache already clean)"
  else
    msg "✓  Cleanup complete: ${removed} files removed, ${size_human} freed"
  fi
}

# Combined Linux-TKG + Nvidia-all install (build both, then pacman -U)
run_linux_nvidia() {
  SECONDS=0
  local epoch_start
  epoch_start=$(date +%s)

  gum style --foreground "$GUM_FG" --bold \
    "Linux-TKG + Nvidia-all combined install (damachine staging fork)"
  echo

  # --- Config merging: ext config → repo config → ext wins ---
  local pf_version="" pf_nvidia_open="" pf_nvidia_open_variant="" pf_compiler=""
  local ext_cfg="${CFG_DIR}/linux-tkg.cfg"

  # Read user ext config
  if [[ -f "$ext_cfg" ]]; then
    local ev eno ec
    ev=$(cfg_val '_version' "$ext_cfg")
    eno=$(cfg_val '_nvidia_open' "$ext_cfg")
    ec=$(cfg_val '_compiler' "$ext_cfg")
    [[ -n "$ev" ]] && pf_version="$ev"
    [[ -n "$eno" ]] && pf_nvidia_open="$eno"
    [[ -n "$ec" ]] && pf_compiler="$ec"
  fi

  # Override with repo customization.cfg if already cloned
  local linux_cfg="${CACHE}/linux/customization.cfg"
  if [[ -f "$linux_cfg" ]]; then
    local cv cno cc
    cv=$(cfg_val '_version' "$linux_cfg")
    cno=$(cfg_val '_nvidia_open' "$linux_cfg")
    cc=$(cfg_val '_compiler' "$linux_cfg")
    [[ -n "$cv" ]] && pf_version="$cv"
    [[ -n "$cno" ]] && pf_nvidia_open="$cno"
    [[ -n "$cc" ]] && pf_compiler="$cc"
    # ext config takes priority
    if [[ -f "$ext_cfg" ]]; then
      ev=$(cfg_val '_version' "$ext_cfg")
      eno=$(cfg_val '_nvidia_open' "$ext_cfg")
      ec=$(cfg_val '_compiler' "$ext_cfg")
      [[ -n "$ev" ]] && pf_version="$ev"
      [[ -n "$eno" ]] && pf_nvidia_open="$eno"
      [[ -n "$ec" ]] && pf_compiler="$ec"
    fi
  fi

  # --- Prompt for _nvidia_open if not set in config ---
  if [[ -n "$pf_nvidia_open" ]]; then
    if normalize_nvidia_open_value "$pf_nvidia_open"; then
      pf_nvidia_open="$RESOLVED_NVIDIA_OPEN"
      pf_nvidia_open_variant="$RESOLVED_NVIDIA_OPEN_VARIANT"
    else
      warn "Ignoring invalid _nvidia_open value in config: $pf_nvidia_open"
      pf_nvidia_open=""
    fi
  fi

  if [[ -z "$pf_nvidia_open" ]]; then
    echo
    gum style --foreground "$GUM_FG" --bold "NVIDIA Open Module — which driver version?"
    echo
    msg "Supported kernels: 6.12  6.18  6.19  7.0  │  Requires Turing+ GPU (RTX 20xx+)"
    msg "Set _nvidia_open in ~/.config/frogminer/linux-tkg.cfg to one of the numeric versions below"
    echo

    local nv_choice
    nv_choice=$(gum choose \
      --header "Select NVIDIA open driver version:" \
      --header.foreground "$GUM_FG" \
      --cursor.foreground "$GUM_FG" \
      "${NVIDIA_OPEN_VERSIONS[latest]} — default branch" \
      "${NVIDIA_OPEN_VERSIONS[vulkan]} — Vulkan developer beta" \
      "${NVIDIA_OPEN_VERSIONS[legacy]} — legacy/LTS branch" \
      "Cancel")

    case "$nv_choice" in
      "${NVIDIA_OPEN_VERSIONS[latest]}"*)
        pf_nvidia_open="${NVIDIA_OPEN_VERSIONS[latest]}"
        pf_nvidia_open_variant="latest"
        ;;
      "${NVIDIA_OPEN_VERSIONS[vulkan]}"*)
        pf_nvidia_open="${NVIDIA_OPEN_VERSIONS[vulkan]}"
        pf_nvidia_open_variant="vulkan"
        ;;
      "${NVIDIA_OPEN_VERSIONS[legacy]}"*)
        pf_nvidia_open="${NVIDIA_OPEN_VERSIONS[legacy]}"
        pf_nvidia_open_variant="legacy"
        ;;
      Cancel | "") die "Cancelled by user." ;;
    esac
    msg "Selected: ${pf_nvidia_open}"
  fi

  # Resolve driver version and branch from version map
  local driver_version="$pf_nvidia_open"
  if [[ -z "${pf_nvidia_open_variant:-}" ]]; then
    normalize_nvidia_open_value "$pf_nvidia_open"
    pf_nvidia_open="$RESOLVED_NVIDIA_OPEN"
    pf_nvidia_open_variant="$RESOLVED_NVIDIA_OPEN_VARIANT"
    driver_version="$RESOLVED_NVIDIA_OPEN"
  fi
  local driver_branch=""
  case "$pf_nvidia_open_variant" in
    vulkan) driver_branch="vulkandev" ;;
    *) driver_branch="regular" ;;
  esac

  # --- Makedeps: linux-tkg ---
  local -a ltkg_makedeps=(
    'bc' 'bison' 'cpio' 'docbook-xsl' 'flex' 'git' 'graphviz'
    'gettext' 'imagemagick' 'inetutils' 'libelf' 'pahole'
    'patchutils' 'perl' 'python' 'python-sphinx' 'python-sphinx_rtd_theme'
    'rust' 'rust-bindgen' 'rust-src' 'tar' 'wget' 'xmlto' 'xz' 'zstd'
  )
  [[ "$pf_compiler" == "llvm" ]] && ltkg_makedeps+=('clang' 'llvm' 'lld')
  msg "Checking linux-tkg build dependencies…"
  ensure_packages "${ltkg_makedeps[@]}" || return 1

  # --- Build linux-tkg (build only) ---
  local linux_preset="${CACHE}/linux_tkg_preset.cfg"
  mkdir -p "$CACHE"
  if [[ -f "$ext_cfg" ]]; then
    cat "$ext_cfg" >"$linux_preset"
    echo >>"$linux_preset"
  else
    : >"$linux_preset"
  fi
  [[ -n "$pf_version" ]] && printf '_version=%q\n' "$pf_version" >>"$linux_preset"
  [[ -n "$pf_nvidia_open" ]] && printf '_nvidia_open=%q\n' "$pf_nvidia_open" >>"$linux_preset"

  local build_cmd="rm -f BIG_UGLY_FROGMINER && _EXT_CONFIG_PATH=\"${linux_preset}\" makepkg -d"
  fetch_repo "linux" "$STAGING_LINUX"
  local linux_dir="${CACHE}/linux"
  copy_config "linux"
  cd "$linux_dir"
  echo
  gum style --foreground "$GUM_FG" --bold "Building Linux-TKG ..."
  echo
  eval "$build_cmd"
  local rc=$?
  local linux_dur="$SECONDS"

  if ((rc != 0)); then
    die "Linux-TKG build failed — skipping Nvidia-all build."
  fi

  # --- Makedeps: nvidia-all ---
  local -a nv_makedeps=(
    'linux-headers' 'patchelf'
    'jansson' 'gtk3' 'libxv' 'libvdpau' 'libxext' 'vulkan-headers'
  )
  msg "Checking nvidia-all build dependencies…"
  ensure_packages "${nv_makedeps[@]}" || return 1

  # --- Build nvidia-all (build only) ---
  SECONDS=0
  local nvidia_preset_dir="${CACHE}/nvidia_all_preset"
  local nvidia_preset="${nvidia_preset_dir}/pre-customization.cfg"
  mkdir -p "$nvidia_preset_dir"

  cat >"$nvidia_preset" <<NVIDIA_CUSTOMIZATION_CFG
# nvidia-all preset config — generated by tkginstaller (linux-nvidia combined install)
_EXT_CONFIG_PATH="~/.tkg_installer_ignored_config_path/nvidia-all.cfg"
CUSTOM_GCC_PATH=""
_series_in_pkgname=""
_kerneloverride=""
_local_package_storing=""
_build_utils_package_only="true"
_lib32="true"
_opencl="true"
_nvsettings="true"
_libxnvctrl="true"
_eglwayland="external"
_eglgbm="external"
_eglx11="external"
_driver_version="${driver_version}"
_driver_branch="${driver_branch}"
_md5sum="SKIP"
_open_source_modules="false"
_module_signing="false"
_blacklist_nouveau="true"
_modprobe="true"
_modprobe_mobile=""
_perf_optimizations="true"
_nvidia_patch_enc_fbc="true"
_bsb_dsc_fix="true"
_only_update_if_newer=""
_dkms="false"
_target_kernel=""
_gcc15_fix="false"
_disable_libalpm_hook=""
_gcc14_fix="false"
_54_prime_fixing_attempt="false"
_62142_fix="false"
NVIDIA_CUSTOMIZATION_CFG

  build_cmd="rm -f options && mv \"${nvidia_preset}\" customization.cfg && makepkg -d"
  fetch_repo "nvidia" "$STAGING_NVIDIA"
  local nvidia_dir="${CACHE}/nvidia"
  copy_config "nvidia"
  cd "$nvidia_dir"
  echo
  gum style --foreground "$GUM_FG" --bold "Building Nvidia-all ..."
  echo
  eval "$build_cmd"
  rc=$?
  local nvidia_dur="$SECONDS"

  rm -rf "$nvidia_preset_dir"

  if ((rc != 0)); then
    die "Nvidia-all build failed — aborting combined install."
  fi

  # --- Collect all built packages and install at once ---
  local -a pkgs=()
  while IFS= read -r -d '' p; do
    pkgs+=("$p")
  done < <(find "$nvidia_dir" "$linux_dir" -maxdepth 1 -name '*.pkg.tar*' -print0 2>/dev/null)

  if ((${#pkgs[@]} == 0)); then
    die "No built packages found."
  fi

  echo
  gum style --foreground "$GUM_FG" --bold \
    "Installing ${#pkgs[@]} packages via pacman -U ..."
  for p in "${pkgs[@]}"; do
    msg "  $(basename "$p")"
  done
  echo

  sudo pacman -U "${pkgs[@]}"
  rc=$?

  # Cleanup built packages on success
  if ((rc == 0)); then
    msg "Cleaning up built packages..."
    find "$linux_dir" "$nvidia_dir" -maxdepth 1 -name '*.pkg.tar*' -delete 2>/dev/null
  fi

  # --- Combined summary ---
  local total=$(($(date +%s) - epoch_start))
  echo
  gum style --foreground "$GUM_WARN" "Completed: $(date '+%Y-%m-%d %H:%M:%S')"
  if ((rc == 0)); then
    msg "✓  Linux-TKG + Nvidia-all — installed successfully"
  else
    gum style --foreground "$GUM_ERR" "✗  Linux-TKG + Nvidia-all — failed (exit ${rc})"
  fi
  gum style --foreground "$GUM_WARN" \
    "Linux-TKG build:  $((linux_dur / 60)) min $((linux_dur % 60)) sec"
  gum style --foreground "$GUM_WARN" \
    "Nvidia-all build: $((nvidia_dur / 60)) min $((nvidia_dur % 60)) sec"
  gum style --foreground "$GUM_WARN" \
    "Combined total:   $((total / 60)) min $((total % 60)) sec"

  return "$rc"
}

# --- Config menu ---

config_menu() {
  while true; do
    header
    local choices=()
    for k in linux nvidia mesa wine proton dxvk vkd3d gamescope glibc amdgpu amdvlk; do
      [[ -n "${CFG[$k]:-}" ]] && choices+=("${LABEL[$k]}")
    done
    choices+=("Back")

    local lbl
    lbl=$(gum choose \
      --header "Edit config for:" \
      --header.foreground "$GUM_FG" \
      --cursor.foreground "$GUM_FG" \
      "${choices[@]}")

    [[ "$lbl" == "Back" || -z "$lbl" ]] && break

    local pkg=""
    for k in "${!LABEL[@]}"; do
      [[ "${LABEL[$k]}" == "$lbl" ]] && pkg="$k" && break
    done
    [[ -z "$pkg" ]] && continue

    run_config "$pkg"
    echo
    gum input --placeholder "Press Enter to continue..."
  done
}

# --- Menu ---

pick_pkg() {
  local choices=()
  choices+=("Linux+Nvidia")
  for k in linux nvidia mesa wine proton dxvk vkd3d gamescope glibc amdgpu amdvlk; do
    [[ -n "${REPO[$k]:-}${CFG[$k]:-}" ]] && choices+=("${LABEL[$k]}")
  done
  choices+=("Clean")
  choices+=("Exit")

  gum choose \
    --header "Select a package:" \
    --header.foreground "$GUM_FG" \
    --cursor.foreground "$GUM_FG" \
    --height 14 \
    "${choices[@]}"
}

label_to_key() {
  local lbl="$1"
  [[ "$lbl" == "Linux+Nvidia" ]] && echo "linux-nvidia" && return
  for k in "${!LABEL[@]}"; do
    [[ "${LABEL[$k]}" == "$lbl" ]] && echo "$k" && return
  done
  echo ""
}

pick_action() {
  local pkg="$1"
  local label="${LABEL[$pkg]:-$pkg}"
  local opts=()

  # Config-only packages (no REPO entry) get only Edit Config
  if [[ -z "${REPO[$pkg]:-}" ]]; then
    opts=("Edit Config" "Back")
  elif [[ "$pkg" == "linux-nvidia" ]]; then
    opts=("Install / Build" "Back")
  elif [[ -n "${CFG[$pkg]:-}" ]]; then
    opts=("Install / Build" "Edit Config" "Back")
  else
    opts=("Install / Build" "Back")
  fi

  gum choose \
    --header "${label} — what to do?" \
    --header.foreground "$GUM_FG" \
    --cursor.foreground "$GUM_FG" \
    "${opts[@]}"
}

menu() {
  while true; do
    header
    local lbl
    lbl=$(pick_pkg)

    [[ "$lbl" == "Exit" || -z "$lbl" ]] && break
    [[ "$lbl" == "Clean" ]] && {
      clean_cache
      echo
      gum input --placeholder "Press Enter to continue..."
      continue
    }

    local pkg
    pkg=$(label_to_key "$lbl")
    [[ -z "$pkg" ]] && continue

    local action
    action=$(pick_action "$pkg")

    case "$action" in
      "Install / Build")
        case "$pkg" in
          linux-nvidia) run_linux_nvidia ;;
          linux) run_linux ;;
          wine) run_wine ;;
          glibc) run_glibc ;;
          proton) run_proton ;;
          dxvk) prep_dxvk ;;
          *) run_install "$pkg" ;;
        esac
        ;;
      "Edit Config") run_config "$pkg" ;;
      "Back" | "") continue ;;
    esac
  done
}

# --- Entry point ---

main() {
  check_deps
  detect_distro
  check_root

  # Direct mode: tkginstaller [command] [pkg]
  if (($# > 0)); then
    local cmd
    cmd=$(normalize "$1")
    [[ -z "$cmd" ]] && die "Unknown command: $1"

    case "$cmd" in
      help)
        show_help
        return 0
        ;;
      clean)
        clean_cache
        return 0
        ;;
      config)
        # tkginstaller config [pkg]
        if [[ -n "${2:-}" ]]; then
          local cpkg
          cpkg=$(normalize "$2")
          [[ -z "$cpkg" ]] && die "Unknown package: $2"
          run_config "$cpkg"
        else
          config_menu
        fi
        return 0
        ;;
      *)
        # tkginstaller [pkg] [config]
        if [[ "${2:-}" =~ ^(config|c|edit|e)$ ]]; then
          run_config "$cmd"
        elif [[ "$cmd" == "linux-nvidia" ]]; then
          run_linux_nvidia
        else
          case "$cmd" in
            linux) run_linux ;;
            wine) run_wine ;;
            glibc) run_glibc ;;
            proton) run_proton ;;
            dxvk) prep_dxvk ;;
            *) run_install "$cmd" ;;
          esac
        fi
        return
        ;;
    esac
  fi

  # Interactive TUI
  menu
}

main "$@"
