check_deps() {
  local missing=()
  for dep in gum git makepkg curl; do
    command -v "$dep" &>/dev/null || missing+=("$dep")
  done
  if ((${#missing[@]} > 0)); then
    echo "Missing required dependencies: ${missing[*]}"
    echo "Install with: sudo pacman -S ${missing[*]}"
    exit 1
  fi

  # Optional deps — warn but don't fail
  local opt_missing=()
  for dep in onefetch schedtool ccache; do
    command -v "$dep" &>/dev/null || opt_missing+=("$dep")
  done
  if ((${#opt_missing[@]} > 0)); then
    warn "Optional tools not found: ${opt_missing[*]}"
    msg "  Install for a better experience: sudo pacman -S ${opt_missing[*]}"
    echo
  fi
}

