# nvidia-open version map — keep in sync with damachine/nvidia-all PKGBUILD
declare -A NVIDIA_OPEN_VERSIONS=(
  [latest]="595.71.05"
  [vulkan]="595.44.06"
  [legacy]="580.159.03"
)

normalize_nvidia_open_value() {
  local value="${1:-}"

  RESOLVED_NVIDIA_OPEN=""
  RESOLVED_NVIDIA_OPEN_VARIANT=""

  case "$value" in
    "" | "false")
      return 0
      ;;
    latest | "${NVIDIA_OPEN_VERSIONS[latest]}")
      RESOLVED_NVIDIA_OPEN="${NVIDIA_OPEN_VERSIONS[latest]}"
      RESOLVED_NVIDIA_OPEN_VARIANT="latest"
      ;;
    vulkan | "${NVIDIA_OPEN_VERSIONS[vulkan]}")
      RESOLVED_NVIDIA_OPEN="${NVIDIA_OPEN_VERSIONS[vulkan]}"
      RESOLVED_NVIDIA_OPEN_VARIANT="vulkan"
      ;;
    legacy | "${NVIDIA_OPEN_VERSIONS[legacy]}")
      RESOLVED_NVIDIA_OPEN="${NVIDIA_OPEN_VERSIONS[legacy]}"
      RESOLVED_NVIDIA_OPEN_VARIANT="legacy"
      ;;
    *)
      return 1
      ;;
  esac

  return 0
}

