}

# Compare local config with upstream — show deprecated + new vars
check_config() {
  local config_file="$1"
  local upstream_url="$2"
  local pkg_name="$3"

  [[ ! -f "$config_file" ]] && return 0

  # Download upstream config to temp
  local tmp_upstream
  tmp_upstream=$(mktemp /tmp/tkg_upstream_XXXXXX.cfg)
  if ! curl "${CURL_OPTS[@]}" "$upstream_url" -o "$tmp_upstream" 2>/dev/null; then
    warn "Could not download upstream config for comparison."
    rm -f "$tmp_upstream"
    return 1
  fi

  # Extract variable names from both configs
  local local_vars upstream_vars upstream_vars_deprecated
  local_vars=$(grep -oP '^#?\s*\K[_a-zA-Z][_a-zA-Z0-9]*(?==)' "$config_file" 2>/dev/null | sort -u)
  upstream_vars=$(grep -oP '^#?\s*\K[_a-zA-Z][_a-zA-Z0-9]*(?==)' "$tmp_upstream" 2>/dev/null | sort -u)
  upstream_vars_deprecated="$upstream_vars"

  # Fetch extra config sources for extended var detection
  local -a extra_urls=()
  case "$pkg_name" in
    linux)
      local tmp_prepare
      tmp_prepare=$(mktemp /tmp/tkg_prepare_XXXXXX)
      if curl "${CURL_OPTS[@]}" "${FROG_RAW}/linux-tkg/master/linux-tkg-config/prepare" -o "$tmp_prepare" 2>/dev/null; then
        local officially_deprecated
        officially_deprecated=$(sed -n '/_deprecated_config_vars=($/,/^)$/p' "$tmp_prepare" | grep -oP '^\s*"_\K[^"]+' | sed 's/^/_/')
        [[ -n "$officially_deprecated" ]] && upstream_vars_deprecated+=$'\n'"$officially_deprecated"
        local prepare_vars
        prepare_vars=$(grep -oP '^#?\s*\K[_a-zA-Z][_a-zA-Z0-9]*(?==)' "$tmp_prepare" 2>/dev/null)
        [[ -n "$prepare_vars" ]] && upstream_vars_deprecated+=$'\n'"$prepare_vars"
        rm -f "$tmp_prepare"
      fi
      ;;
    wine)
      extra_urls=(
        "${FROG_RAW}/wine-tkg-git/refs/heads/master/wine-tkg-git/wine-tkg-profiles/advanced-customization.cfg"
        "${FROG_RAW}/wine-tkg-git/refs/heads/master/wine-tkg-git/wine-tkg-profiles/sample-external-config.cfg"
      )
      ;;
    proton)
      extra_urls=(
        "${FROG_RAW}/wine-tkg-git/refs/heads/master/proton-tkg/proton-tkg-profiles/advanced-customization.cfg"
        "${FROG_RAW}/wine-tkg-git/refs/heads/master/proton-tkg/proton-tkg-profiles/sample-external-config.cfg"
      )
      ;;
  esac

  # Merge extra config vars
  for url in "${extra_urls[@]}"; do
    local tmp_extra
    tmp_extra=$(mktemp /tmp/tkg_extra_XXXXXX.cfg)
    if curl "${CURL_OPTS[@]}" "$url" -o "$tmp_extra" 2>/dev/null; then
      local extra_vars
      extra_vars=$(grep -oP '^#?\s*\K[_a-zA-Z][_a-zA-Z0-9]*(?==)' "$tmp_extra" 2>/dev/null)
      [[ -n "$extra_vars" ]] && {
        upstream_vars+=$'\n'"$extra_vars"
        upstream_vars_deprecated+=$'\n'"$extra_vars"
      }
      rm -f "$tmp_extra"
    fi
  done

  # Sort and deduplicate
  upstream_vars=$(echo "$upstream_vars" | sort -u)
  upstream_vars_deprecated=$(echo "$upstream_vars_deprecated" | sort -u)

  # Find deprecated + new variables
  local deprecated_vars new_vars
  deprecated_vars=$(comm -23 <(echo "$local_vars") <(echo "$upstream_vars_deprecated") 2>/dev/null)
  new_vars=$(comm -13 <(echo "$local_vars") <(echo "$upstream_vars") 2>/dev/null)

  # Nothing to report
  [[ -z "$deprecated_vars" && -z "$new_vars" ]] && {
    rm -f "$tmp_upstream"
    return 0
  }

  # Display results
  echo
  gum style --foreground "$GUM_FG" --bold \
    "CONFIG CHECK — ${config_file}"
  echo

  if [[ -n "$deprecated_vars" ]]; then
    gum style --foreground "$GUM_WARN" --bold "Deprecated variables (no longer used upstream):"
    echo
    while IFS= read -r var; do
      [[ -n "$var" ]] && gum style --foreground "$GUM_ERR" "  ✗  ${var}"
    done <<<"$deprecated_vars"
    echo
  fi

  if [[ -n "$new_vars" ]]; then
    gum style --foreground "$GUM_FG" --bold "New variables available upstream:"
    echo
    while IFS= read -r var; do
      [[ -n "$var" ]] && gum style --foreground "$GUM_FG" "  +  ${var}"
    done <<<"$new_vars"
    echo
  fi

  msg "Review upstream config for details:"
  gum style --foreground "$GUM_WARN" "  ${upstream_url}"
  for url in "${extra_urls[@]}"; do
    gum style --foreground "$GUM_WARN" "  ${url}"
  done
  echo
  gum input --placeholder "Press Enter to continue..."

  rm -f "$tmp_upstream"
}

# Detect Linux distribution
detect_distro() {
  if [[ -f /etc/os-release ]]; then
    # shellcheck disable=SC1091
    . /etc/os-release
    DISTRO_NAME="$NAME"
    DISTRO_ID="${ID:-unknown}"
    local distro_like="${ID_LIKE:-}"
  else
    DISTRO_NAME="Unknown"
    DISTRO_ID="unknown"
    local distro_like=""
  fi

  if [[ "${DISTRO_ID,,}" =~ ^(arch|cachyos|manjaro|endeavouros)$ || "${distro_like,,}" == *"arch"* ]]; then
    IS_ARCH=true
  else
    IS_ARCH=false
  fi
}

# Warn if running as root
check_root() {
  if [[ "$(id -u)" -eq 0 ]]; then
    warn "You are running as root!"
    echo
    msg "Running this script as root is not recommended."
    echo
    if ! gum confirm "Continue as root?"; then
      die "Aborted by user."
    fi
  fi
}

