# DXVK/vkd3d-proton pre-build for Proton-TKG
prep_dxvk() {
  echo
  msg "Note: Proton-TKG downloads official DXVK by default."
  msg "Set _use_dxvk=\"prebuilt\" in proton-tkg.cfg to use custom builds."
  echo

  local choice
  choice=$(gum choose \
    --header "DXVK/vkd3d — pre-build for Proton-TKG:" \
    --header.foreground "$GUM_FG" \
    --cursor.foreground "$GUM_FG" \
    "Both      (DXVK + vkd3d-proton)" \
    "DXVK only" \
    "vkd3d only" \
    "Skip      (continue with Proton)" \
    "Cancel")

  local build_dxvk=false build_vkd3d=false

  case "$choice" in
    Both*)
      build_dxvk=true
      build_vkd3d=true
      ;;
    DXVK*) build_dxvk=true ;;
    vkd3d*) build_vkd3d=true ;;
    Skip*) return 0 ;;
    Cancel | "") return 1 ;;
  esac

  # Clone/update dxvk-tools
  fetch_repo "dxvk" "${REPO[dxvk]}"
  cd "${CACHE}/dxvk"

  local built_something=false

  if [[ "$build_dxvk" == "true" ]]; then
    msg "Building DXVK..."
    if ./updxvk build; then
      built_something=true
    else
      warn "DXVK build failed"
    fi
  fi

  if [[ "$build_vkd3d" == "true" ]]; then
    msg "Building vkd3d-proton..."
    if ./upvkd3d-proton build; then
      built_something=true
    else
      warn "vkd3d build failed"
    fi
  fi

  if [[ "$built_something" == "true" ]]; then
    if gum confirm "Export builds for Proton-TKG?"; then
      ./updxvk proton-tkg
    fi
  fi
}

# Proton-TKG install — with optional DXVK/vkd3d preparation
run_proton() {
  # Pre-clone proton repo so prep_dxvk can find the workdir
  show_pkg_info "proton"
  fetch_repo "proton"

  # Optional DXVK/vkd3d preparation
  prep_dxvk || warn "dxvk-tools prep skipped"

  # Build Proton
  run_install "proton" "./proton-tkg.sh"
  local rc=$?

  # Offer cleanup after successful build
  if ((rc == 0)); then
    if gum confirm "Run 'proton-tkg.sh clean'?"; then
      run_install "proton" "./proton-tkg.sh clean" "1"
    fi
  fi

  return "$rc"
}

