# Countdown prompt with timeout
__prompt_timer() {
  local _prompt_options="${1:-[1/2]}"
  local _timeout="${2:-60}"
  local _default="${3:-1}"
  local _old_trap_int=""

  _old_trap_int=$(trap -p INT 2>/dev/null)

  _seconds_left="${_timeout}"
  _user_answer=""
  local _abort_flag=false

  # Simple progress display
  while [[ ${_seconds_left} -gt 0 && ${_abort_flag} == false ]]; do
    # Set trap inside loop so break works correctly
    trap '__clear_line 120 ""; echo; echo; msgplain "${_red}Aborted by user!${break}"; _abort_flag=true; break' INT

    # Display prompt
    printf "\r${gray}%s ${reset}  ${orange}%02d${gray}s ${reset}  %s" \
      "${_prompt_options}" "${_seconds_left}"

    if read -r -t 1 -n 1 _key </dev/tty; then
      # Enter = accept default
      if [[ -z "${_key}" ]]; then
        _user_answer="${_default}"
        __clear_line 120 ""
        break
      fi
      # Accept only digit keys
      if [[ "${_key}" =~ ^[0-9]$ ]]; then
        _user_answer="${_key}"
        break
      else
        # Non-digit pressed
        continue
      fi
    fi
    ((_seconds_left--))
  done

  # Handle abort
  if [[ ${_abort_flag} == true ]]; then
    sleep 1.5s
    exit 130
  fi

  # Default if no answer
  : "${_user_answer:=${_default}}"

  # Sanitize input
  _user_answer="${_user_answer//[[:space:]]/}"
  _user_answer="${_user_answer//[^0-9]/}"
  _user_answer="${_user_answer:0:1}"

  __clear_line 120 ""

  # Restore previous INT trap
  if [[ -n "${_old_trap_int}" ]]; then
    eval "${_old_trap_int}"
  else
    trap - INT
  fi
}

# Prompt user with default value
__prompt_answer() {
  local _default="${1:-n}"
  read -r _user_answer
  : "${_user_answer:=${_default}}"
}

# Linux-TkG installation
__linux_install() {
  msgpkg "Linux-TkG" "${frog_repo_url}/linux-tkg/blob/master/customization.cfg"

  # Repository source selection
  local _linux_repo="${_frog_pkg_repo[linux]}"
  local _linux_branch="master"
  msginfo "${break}${neon}${uline_on}SOURCE${uline_off}:${reset} ${light}Which Linux-TkG repository do you want to use?${reset}${break}"
  msgplain " ${neon}${uline_on}0${uline_off}${reset} │ Upstream       ${gray}${frog_repo_url}/linux-tkg${reset}"
  msgplain " ${orange}1${reset} │ Staging fork   ${gray}https://github.com/damachine/linux-tkg${reset} ${orange}(branch: staging)${reset}${break}"
  __prompt_timer "[${neon}${uline_on}0${uline_off}${reset}/${orange}1${reset}]" 60 0
  case "${_user_answer}" in
    1)
      _linux_repo="${damachine_linux_tkg_repo}"
      _linux_branch="staging"
      ;;
    *)
      _linux_repo="${_frog_pkg_repo[linux]}"
      _linux_branch="master"
      ;;
  esac

  local _build_command

  if [[ "${_is_arch_based}" == "true" ]]; then
    __build_menu "Linux-TkG" \
      "makepkg -si" "recommended for Arch" \
      "install.sh install" "(generic script)" \
      "install.sh uninstall" "(show uninstall help)"

    case "${_menu_choice}" in
      0)
        msginfo "${break}${orange}Cancelled by user${reset}${break}"
        __exit 1
        ;;
      2) _build_command="chmod +x install.sh && ./install.sh install" ;;
      9) _build_command="chmod +x install.sh && ./install.sh uninstall-help" ;;
      *) _build_command="makepkg -si" ;;
    esac
  else
    local _pkg_type=""
    case "${_distro_id,,}" in
      debian | ubuntu | linuxmint | pop | elementary | mx | raspbian) _pkg_type="DEB" ;;
      fedora | rhel | centos | rocky | alma | opensuse* | suse*) _pkg_type="RPM" ;;
    esac

    [[ -n "${_pkg_type}" ]] && msginfo "${break}${neon}${uline_on}INFO${uline_off}:${reset}${light} ${_pkg_type}-based distribution detected: ${gray}${_distro_name}${reset}${break}"
    _build_command="chmod +x install.sh && ./install.sh install"
  fi

  __install_package "${_linux_repo}" "linux-tkg" "${_build_command}" "" "" "${_linux_branch}"
  local _status=$?

  # Offer uninstall help for non-Arch
  if [[ "${_is_arch_based}" != "true" && ${_status} -eq 0 ]]; then
    msginfo "${break}${neon}${uline_on}TIP${uline_off}:${reset}${light} Uninstalling custom kernels has to be done manually.${break}"
    msgprompt "Show uninstall info now? [y/N]: "
    read -r _show_info
    [[ "${_show_info,,}" =~ ^(y|yes)$ ]] && { cd "${tkg_tmp_dir}/linux-tkg" && ./install.sh uninstall-help; }
  fi

  return "${_status:-0}"
}

# Linux-TkG AutoFDO installation (Pass 1: profilable build / Pass 2: optimized rebuild)
__linux_autofdo_install() {
  local _autofdo_pass="${1:-pass1}"
  local _afdo_profile="${HOME}/.config/frogminer/tkg.afdo"

  msgpkg "Linux-TkG AutoFDO ${_autofdo_pass^^}" "${frog_repo_url}/linux-tkg/blob/master/customization.cfg"

  # Pass 2: verify profile exists before proceeding
  if [[ "${_autofdo_pass}" == "pass2" ]]; then
    if [[ ! -f "${_afdo_profile}" ]]; then
      msgerror "AutoFDO Pass 2 requires a profile at: ${gray}${_afdo_profile}${reset}${break}"
      msgplain " Run ${orange}$0 linux pass1${reset} first, collect perf data and generate the .afdo profile.${break}"
      return 1
    fi
    msginfo "${break}${neon}${uline_on}AUTOFDO PASS 2${uline_off}:${reset} ${light}Optimized rebuild using profile:${reset} ${gray}${_afdo_profile}${reset}${break}"
  else
    msginfo "${break}${neon}${uline_on}AUTOFDO PASS 1${uline_off}:${reset} ${light}Profilable kernel build${reset} ${gray}(LLVM, _STRIP=false — required for AutoFDO)${reset}${break}"
  fi

  # Repository source selection
  local _linux_repo="${_frog_pkg_repo[linux]}"
  local _linux_branch="master"
  msginfo "${break}${neon}${uline_on}SOURCE${uline_off}:${reset} ${light}Which Linux-TkG repository do you want to use?${reset}${break}"
  msgplain " ${neon}${uline_on}0${uline_off}${reset} │ Upstream       ${gray}${frog_repo_url}/linux-tkg${reset}"
  msgplain " ${orange}1${reset} │ Staging fork   ${gray}https://github.com/damachine/linux-tkg${reset} ${orange}(branch: staging)${reset}${break}"
  __prompt_timer "[${neon}${uline_on}0${uline_off}${reset}/${orange}1${reset}]" 60 0
  case "${_user_answer}" in
    1)
      _linux_repo="${damachine_linux_tkg_repo}"
      _linux_branch="staging"
      ;;
    *)
      _linux_repo="${_frog_pkg_repo[linux]}"
      _linux_branch="master"
      ;;
  esac

  # Build preset config — user config as base, AutoFDO overrides on top
  local _autofdo_preset="${tkg_tmp_dir}/linux_autofdo_${_autofdo_pass}_preset.cfg"
  mkdir -p "${tkg_tmp_dir}"
  local _ltkg_cfg="${HOME}/.config/frogminer/linux-tkg.cfg"
  if [[ -f "${_ltkg_cfg}" ]]; then
    cat "${_ltkg_cfg}" >"${_autofdo_preset}"
    echo >>"${_autofdo_preset}"
  else
    : >"${_autofdo_preset}"
  fi

  # AutoFDO overrides (Pass 1 cannot run with module stripping)
  cat >>"${_autofdo_preset}" <<AUTOFDO_PRESET_CFG
# AutoFDO ${_autofdo_pass^^} overrides — generated by tkginstaller
_compiler="llvm"
_autofdo="true"
_STRIP="false"
AUTOFDO_PRESET_CFG

  if [[ "${_autofdo_pass}" == "pass2" ]]; then
    printf '_autofdo_profile_path="%s"\n' "${_afdo_profile}" >>"${_autofdo_preset}"
  fi

  local _build_command="rm -f BIG_UGLY_FROGMINER && _EXT_CONFIG_PATH=\"${_autofdo_preset}\" makepkg -si"
  __install_package "${_linux_repo}" "linux-tkg" "${_build_command}" "" "" "${_linux_branch}"
  local _status=$?

  # After Pass 1: show next-steps guide
  if [[ "${_autofdo_pass}" == "pass1" && ${_status} -eq 0 ]]; then
    msginfo "${break}${neon}${uline_on}NEXT STEPS${uline_off}:${reset} ${light}After booting the new kernel:${reset}${break}"
    msgplain " ${gray}1. Unlock kernel pointers (run as root):${reset}"
    msgplain "    ${orange}sysctl -w kernel.kptr_restrict=0 kernel.perf_event_paranoid=0${reset}${break}"
    msgplain " ${gray}2. Collect perf data — Intel LBR:${reset}"
    msgplain "    ${orange}perf record -e BR_INST_RETIRED.NEAR_TAKEN:k -a -N -b -c 500009 -o kernel.data -- <workload>${reset}"
    msgplain " ${gray}   AMD Zen4:${reset}"
    msgplain "    ${orange}perf record --pfm-events RETIRED_TAKEN_BRANCH_INSTRUCTIONS:k -a -N -b -c 500009 -o kernel.data -- <workload>${reset}${break}"
    msgplain " ${gray}3. Convert to .afdo profile:${reset}"
    msgplain "    ${orange}mkdir -p ~/.config/frogminer${reset}"
    msgplain "    ${orange}llvm-profgen --kernel --binary=/usr/lib/modules/\$(uname -r)/build/vmlinux \\${reset}"
    msgplain "    ${orange}  --perfdata=kernel.data -o ~/.config/frogminer/tkg.afdo${reset}${break}"
    msgplain " ${gray}4. Rebuild optimized kernel:${reset} ${neon}$0 linux pass2${reset}${break}"
  fi

  return "${_status:-0}"
}

