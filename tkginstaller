# Linux-TkG AutoFDO installation (Pass 1: profilable build / Pass 2: optimized rebuild)
__linux_autofdo_install() {
  local _autofdo_pass="${1:-pass1}"
  local _afdo_profile="${HOME}/.config/frogminer/tkg.afdo"

  __msg_pkg "Linux-TkG AutoFDO ${_autofdo_pass^^}" "${_frog_repo_url}/linux-tkg/blob/master/customization.cfg"

  # Pass 2: verify profile exists before proceeding
  if [[ "${_autofdo_pass}" == "pass2" ]]; then
    if [[ ! -f "${_afdo_profile}" ]]; then
      __msg_error "AutoFDO Pass 2 requires a profile at: ${_gray}${_afdo_profile}${_reset}${_break}"
      __msg_plain " Run ${_orange}$0 linux pass1${_reset} first, collect perf data and generate the .afdo profile.${_break}"
      return 1
    fi
    __msg_info "${_break}${_green_neon}${_uline_on}AUTOFDO PASS 2${_uline_off}:${_reset} ${_green_light}Optimized rebuild using profile:${_reset} ${_gray}${_afdo_profile}${_reset}${_break}"
  else
    __msg_info "${_break}${_green_neon}${_uline_on}AUTOFDO PASS 1${_uline_off}:${_reset} ${_green_light}Profilable kernel build${_reset} ${_gray}(LLVM, _STRIP=false — required for AutoFDO)${_reset}${_break}"
  fi

  # Repository source selection
  local _linux_repo="${_frog_pkg_repo[linux]}"
  __msg_info "${_break}${_green_neon}${_uline_on}SOURCE${_uline_off}:${_reset} ${_green_light}Which Linux-TkG repository do you want to use?${_reset}${_break}"
  __msg_plain " ${_green_neon}${_uline_on}0${_uline_off}${_reset} │ Upstream       ${_gray}${_frog_repo_url}/linux-tkg${_reset}"
  __msg_plain " ${_orange}1${_reset} │ Staging fork   ${_gray}https://github.com/damachine/linux-tkg${_reset}${_break}"
  __prompt_timer "[${_green_neon}${_uline_on}0${_uline_off}${_reset}/${_orange}1${_reset}]" 60 0
  case "${_user_answer}" in
    1) _linux_repo="${_damachine_linux_tkg_repo}" ;;
    *) _linux_repo="${_frog_pkg_repo[linux]}" ;;
  esac

  # Build preset config — user config as base, AutoFDO overrides on top
  local _autofdo_preset="${_tkg_tmp_dir}/linux_autofdo_${_autofdo_pass}_preset.cfg"
  mkdir -p "${_tkg_tmp_dir}"
  local _ltkg_cfg="${HOME}/.config/frogminer/linux-tkg.cfg"
  if [[ -f "${_ltkg_cfg}" ]]; then
    cat "${_ltkg_cfg}" >"${_autofdo_preset}"
    echo >>"${_autofdo_preset}"
  else
    : >"${_autofdo_preset}"
  fi

  # AutoFDO overrides (Pass 1 cannot run with module stripping)
  cat >>"${_autofdo_preset}" <<AUTOFDO_PRESET_CFG
