# Check if packages are installed; install any missing ones via pacman --needed.
__ensure_packages() {
  local _missing=()
  local _pkg
  for _pkg in "$@"; do
    pacman -Qq "${_pkg}" &>/dev/null || _missing+=("${_pkg}")
  done
  if [[ ${#_missing[@]} -gt 0 ]]; then
    __msg_info "Installing missing build dependencies: ${_missing[*]}${_break}"
    sudo pacman -S --needed --asdeps --noconfirm "${_missing[@]}" || return 1
  fi
}

# Linux-TkG + Nvidia-all combined installation (damachine fork)
# shellcheck disable=SC2218
__linux_nvidia_install() {
  local _combined_epoch
  _combined_epoch=$(date +%s)
  __msg_pkg "Linux-TkG + Nvidia-all" "https://github.com/damachine/linux-tkg/blob/staging/customization.cfg"
  __msg_info "${_break}${_green_neon}${_uline_on}COMBINED${_uline_off}:${_reset} ${_green_light}Both packages will be ${_gray}built first${_reset}${_green_light}, then installed together via ${_gray}pacman -U${_reset}${_green_light} from the damachine staging fork.${_reset}${_break}"

  local _pf_version="" _pf_nvidia="" _pf_nvidia_variant="" _pf_compiler=""
  local _pf_cfg_ext="${HOME}/.config/frogminer/linux-tkg.cfg"

  # read user ext config
  if [[ -f "${_pf_cfg_ext}" ]]; then
    local _ev _eno _ec
    _ev=$(__cfg_val '_version' "${_pf_cfg_ext}")
    _eno=$(__cfg_val '_nvidia' "${_pf_cfg_ext}")
    _ec=$(__cfg_val '_compiler' "${_pf_cfg_ext}")
    [[ -n "${_ev}" ]] && _pf_version="${_ev}"
    [[ -n "${_eno}" ]] && _pf_nvidia="${_eno}"
    [[ -n "${_ec}" ]] && _pf_compiler="${_ec}"
  fi

  # override with repo customization.cfg if already cloned
  local _linux_tkg_dir="${_tkg_tmp_dir}/linux-tkg"
  local _pf_cfg_main="${_linux_tkg_dir}/customization.cfg"
  if [[ -f "${_pf_cfg_main}" ]]; then
    local _cv _cno _cc
    _cv=$(__cfg_val '_version' "${_pf_cfg_main}")
    _cno=$(__cfg_val '_nvidia' "${_pf_cfg_main}")
    _cc=$(__cfg_val '_compiler' "${_pf_cfg_main}")
    [[ -n "${_cv}" ]] && _pf_version="${_cv}"
    [[ -n "${_cno}" ]] && _pf_nvidia="${_cno}"
    [[ -n "${_cc}" ]] && _pf_compiler="${_cc}"
    # ext config wins
    if [[ -f "${_pf_cfg_ext}" ]]; then
      _ev=$(__cfg_val '_version' "${_pf_cfg_ext}")
      _eno=$(__cfg_val '_nvidia' "${_pf_cfg_ext}")
      _ec=$(__cfg_val '_compiler' "${_pf_cfg_ext}")
      [[ -n "${_ev}" ]] && _pf_version="${_ev}"
      [[ -n "${_eno}" ]] && _pf_nvidia="${_eno}"
      [[ -n "${_ec}" ]] && _pf_compiler="${_ec}"
    fi
  fi

  # prompt for _nvidia if not set in config
  if [[ -n "${_pf_nvidia}" ]]; then
    if __resolve_nvidia_value "${_pf_nvidia}"; then
      _pf_nvidia="${_resolved_nvidia}"
      _pf_nvidia_variant="${_resolved_nvidia_variant}"
    else
      __msg_warning "Ignoring invalid _nvidia value in config: ${_pf_nvidia}${_break}"
      _pf_nvidia=""
    fi
  fi

  if [[ -z "${_pf_nvidia}" ]]; then
    __msg_info "${_break}${_green_neon}${_uline_on}NVIDIA OPEN MODULE${_uline_off}:${_reset} ${_green_light}Which NVIDIA open driver version for the combined install?${_reset}${_break}"
    __msg_plain " Supported kernels: ${_gray}6.18  7.0${_reset}  │  Requires Turing+ GPU (GTX 16+ or RTX 20xx or newer)"
    __msg_plain " ${_gray}Set${_reset} ${_gray}_nvidia${_reset} ${_gray}in${_reset} ${_gray}~/.config/frogminer/linux-tkg.cfg${_reset} ${_gray}to one of the numeric versions below.${_reset}${_break}"
    __msg_plain " ${_green_neon}${_uline_on}0${_uline_off}${_reset} │ ${_nvidia_versions[latest]}  ${_gray}— default branch, selected${_reset} ${_green_neon}(default)${_reset}"
    __msg_plain " ${_orange}1${_reset} │ ${_nvidia_versions[vulkan]}  ${_gray}— Vulkan developer beta${_reset}"
    __msg_plain " ${_gray}2${_reset} │ ${_nvidia_versions[legacy]}  ${_gray}— legacy/LTS branch${_reset}"
    __msg_plain " ${_red}9${_reset} │ Cancel${_break}"
    __prompt_timer "[${_green_neon}${_uline_on}0${_uline_off}${_reset}/${_orange}1${_reset}/${_gray}2${_reset}/${_red}9${_reset}]" 60 0
    case "${_user_answer}" in
      1)
        _pf_nvidia="${_nvidia_versions[vulkan]}"
        _pf_nvidia_variant="vulkan"
        ;;
      2)
        _pf_nvidia="${_nvidia_versions[legacy]}"
        _pf_nvidia_variant="legacy"
        ;;
      9)
        __msg_info "${_break}${_orange}Cancelled by user${_reset}${_break}"
        __exit 1
        ;;
      *)
        _pf_nvidia="${_nvidia_versions[latest]}"
        _pf_nvidia_variant="latest"
        ;;
    esac
    __msg_plain "${_break} Selected: ${_gray}${_pf_nvidia}${_reset}"
  fi

  # resolve driver version and branch from version map
  local _driver_version_val="${_pf_nvidia}"
  if [[ -z "${_pf_nvidia_variant}" ]]; then
    __resolve_nvidia_value "${_pf_nvidia}"
    _pf_nvidia="${_resolved_nvidia}"
    _pf_nvidia_variant="${_resolved_nvidia_variant}"
    _driver_version_val="${_resolved_nvidia}"
  fi
  local _driver_branch_val=""
  case "${_pf_nvidia_variant}" in
    vulkan) _driver_branch_val="vulkandev" ;;
    *) _driver_branch_val="regular" ;;
  esac

  # linux-tkg makedeps (kernel ≥ 6.12, rust always included)
  local _ltkg_makedeps=(
    'bc' 'bison' 'cpio' 'docbook-xsl' 'flex' 'git' 'graphviz'
    'gettext' 'imagemagick' 'inetutils' 'libelf' 'pahole'
    'patchutils' 'perl' 'python' 'python-sphinx' 'python-sphinx_rtd_theme'
    'rust' 'rust-bindgen' 'rust-src' 'tar' 'wget' 'xmlto' 'xz' 'zstd'
  )
  if [[ "${_pf_compiler}" == "llvm" ]]; then
    _ltkg_makedeps+=('clang' 'llvm' 'lld')
  fi
  __msg_info "${_break}${_green_neon}${_uline_on}MAKEDEPS${_uline_off}:${_reset} ${_green_light}Checking linux-tkg build dependencies…${_reset}"
  __ensure_packages "${_ltkg_makedeps[@]}" || return 1

  # build linux-tkg
  local _linux_tkg_preset="${_tkg_tmp_dir}/linux_tkg_preset.cfg"
  mkdir -p "${_tkg_tmp_dir}"
  if [[ -f "${_pf_cfg_ext}" ]]; then
    cat "${_pf_cfg_ext}" >"${_linux_tkg_preset}"
    echo >>"${_linux_tkg_preset}"
  else
    : >"${_linux_tkg_preset}"
  fi
  # append chosen values to preset
  [[ -n "${_pf_version}" ]] && printf '_version=%q\n' "${_pf_version}" >>"${_linux_tkg_preset}"
  [[ -n "${_pf_nvidia}" ]] && printf '_nvidia=%q\n' "${_pf_nvidia}" >>"${_linux_tkg_preset}"

  local _build_command="rm -f BIG_UGLY_FROGMINER && _EXT_CONFIG_PATH=\"${_linux_tkg_preset}\" makepkg -d"
  _tkg_skip_status="1"
  __install_package "${_damachine_linux_tkg_repo}" "linux-tkg" "${_build_command}"
  local _status=$?
  local _linux_duration="${SECONDS}"

  if [[ ${_status} -ne 0 ]]; then
    __msg_error "Linux-TkG build failed — skipping Nvidia-all build.${_break}"
    return "${_status}"
  fi

  # nvidia-all makedeps (nvsettings always enabled)
  local _nv_makedeps=('linux-headers' 'patchelf'
    'jansson' 'gtk3' 'libxv' 'libvdpau' 'libxext' 'vulkan-headers')
  __msg_info "${_break}${_green_neon}${_uline_on}MAKEDEPS${_uline_off}:${_reset} ${_green_light}Checking nvidia-all build dependencies…${_reset}"
  __ensure_packages "${_nv_makedeps[@]}" || return 1

  # build nvidia-all
  local _preset_cfg="${_tkg_tmp_dir}/nvidia_all/pre-customization.cfg"
  mkdir -p "${_tkg_tmp_dir}/nvidia_all"

  cat >"${_preset_cfg}" <<NVIDIA_CUSTOMIZATION_CFG
# nvidia-all preset config — generated by tkginstaller (linux-nvidia combined install)
# Edit values in the __write_nvidia_preset_cfg() heredoc inside tkginstaller to customize.
#
# _EXT_CONFIG_PATH is explicitly cleared so ~/.config/frogminer/nvidia-all.cfg does NOT
# override this file. Remove this line only if you want your personal nvidia-all.cfg applied.
_EXT_CONFIG_PATH="~/.tkg_installer_ignored_config_path/nvidia-all.cfg"
CUSTOM_GCC_PATH=""
_series_in_pkgname=""
_kerneloverride=""
_local_package_storing=""
_build_utils_package_only="true"
_lib32="true"
_opencl="true"
_nvsettings="true"
_libxnvctrl="true"
_eglwayland="external"
_eglgbm="external"
_eglx11="external"
_driver_version="${_driver_version_val}"
_driver_branch="${_driver_branch_val}"
_md5sum="SKIP"
_open_source_modules="false"
_module_signing="false"
_blacklist_nouveau="true"
_modprobe="true"
_modprobe_mobile="true"
_perf_optimizations="true"
_nvidia_patch_enc_fbc="true"
_bsb_dsc_fix="true"
_only_update_if_newer=""
_dkms="false"
_target_kernel=""
_gcc15_fix="false"
_disable_libalpm_hook=""
_gcc14_fix="false"
_54_prime_fixing_attempt="false"
_62142_fix="false"
NVIDIA_CUSTOMIZATION_CFG

  # build only
  _build_command="rm -f options && mv \"${_preset_cfg}\" customization.cfg && makepkg -d"
  _tkg_skip_status="1"
  # shellcheck disable=SC2218
  __install_package "${_damachine_nvidia_all_repo}" "nvidia-all" "${_build_command}"
  _status=$?
  local _nvidia_duration="${SECONDS}"

  rm -rf "${_tkg_tmp_dir}/nvidia_all"

  if [[ ${_status} -ne 0 ]]; then
    __msg_error "Nvidia-all build failed — aborting combined install.${_break}"
    return "${_status}"
  fi

  # collect all built packages and install at once
  local _all_pkgs=()
  while IFS= read -r -d '' _pkg; do
    _all_pkgs+=("${_pkg}")
  done < <(find "${_tkg_tmp_dir}/nvidia-all" -maxdepth 1 -name '*.pkg.tar*' -print0 2>/dev/null)
  while IFS= read -r -d '' _pkg; do
    _all_pkgs+=("${_pkg}")
  done < <(find "${_tkg_tmp_dir}/linux-tkg" -maxdepth 1 -name '*.pkg.tar*' -print0 2>/dev/null)

  if [[ ${#_all_pkgs[@]} -eq 0 ]]; then
    __msg_error "No built packages found to install.${_break}"
    return 1
  fi

  __msg_info "${_break}${_green_neon}${_uline_on}INSTALL${_uline_off}:${_reset} ${_green_light}Installing ${_gray}${#_all_pkgs[@]}${_reset}${_green_light} packages via ${_gray}pacman -U${_reset}${_green_light}:${_reset}"
  for _pkg in "${_all_pkgs[@]}"; do
    __msg_plain "  ${_gray}$(basename "${_pkg}")${_reset}"
  done
  __msg_plain "${_break}"

  sudo pacman -U "${_all_pkgs[@]}"
  _status=$?

  # remove built packages after installation
  if [[ ${_status} -eq 0 ]]; then
    __msg_plain "${_break}${_green_neon}Cleaning up built packages...${_reset}"
    find "${_tkg_tmp_dir}/linux-tkg" -maxdepth 1 -name '*.pkg.tar*' -delete 2>/dev/null || true
    find "${_tkg_tmp_dir}/nvidia-all" -maxdepth 1 -name '*.pkg.tar*' -delete 2>/dev/null || true
  fi

  # summary
  local _combined_total=$(($(date +%s) - _combined_epoch))
  local _nv_min=$((_nvidia_duration / 60))
  local _nv_sec=$((_nvidia_duration % 60))
  local _lx_min=$((_linux_duration / 60))
  local _lx_sec=$((_linux_duration % 60))
  local _combined_min=$((_combined_total / 60))
  local _combined_sec=$((_combined_total % 60))

  __msg_info_orange "${_break}Action completed: $(date '+%Y-%m-%d %H:%M:%S')"
  if [[ ${_status} -eq 0 ]]; then
    __msg_info "Status: Linux-TkG + Nvidia-all successfully completed!"
  else
    __msg_error "Failed process: Linux-TkG + Nvidia-all (Code: ${_status})"
  fi
  __msg_info_orange "Duration Linux-TkG build:  ${_lx_min} min ${_lx_sec} sec"
  __msg_info_orange "Duration Nvidia-all build: ${_nv_min} min ${_nv_sec} sec"
  __msg_info_orange "Combined Duration:         ${_combined_min} min ${_combined_sec} sec"
  return "${_status}"
}

