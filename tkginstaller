# Check if packages are installed; install any missing ones via pacman --needed.
__ensure_packages() {
  local _missing=()
  local _pkg
  for _pkg in "$@"; do
    pacman -Qq "${_pkg}" &>/dev/null || _missing+=("${_pkg}")
  done
  if [[ ${#_missing[@]} -gt 0 ]]; then
    msginfo "Installing missing build dependencies: ${_missing[*]}${break}"
    sudo pacman -S --needed --asdeps --noconfirm "${_missing[@]}" || return 1
  fi
}

# Linux-TkG + Nvidia-all combined installation (damachine fork)
# shellcheck disable=SC2218
__linux_nvidia_install() {
  local _combined_epoch
  _combined_epoch=$(date +%s)
  msgpkg "Linux-TkG + Nvidia-all" "https://github.com/damachine/linux-tkg/blob/staging/customization.cfg"
  msginfo "${break}${neon}${uline_on}COMBINED${uline_off}:${reset} ${light}Both packages will be ${gray}built first${reset}${light}, then installed together via ${gray}pacman -U${reset}${light} from the damachine staging fork.${reset}${break}"

  local _pf_version="" _pf_nvidia="" _pf_nvidia_variant="" _pf_compiler=""
  local _pf_cfg_ext="${HOME}/.config/frogminer/linux-tkg.cfg"

  # read user ext config
  if [[ -f "${_pf_cfg_ext}" ]]; then
    local _ev _eno _ec
    _ev=$(__cfg_val '_version' "${_pf_cfg_ext}")
    _eno=$(__cfg_val '_nvidia_pkg' "${_pf_cfg_ext}")
    _ec=$(__cfg_val '_compiler' "${_pf_cfg_ext}")
    [[ -n "${_ev}" ]] && _pf_version="${_ev}"
    [[ -n "${_eno}" ]] && _pf_nvidia="${_eno}"
    [[ -n "${_ec}" ]] && _pf_compiler="${_ec}"
  fi

  # override with repo customization.cfg if already cloned
  local _linux_tkg_dir="${tkg_tmp_dir}/linux-tkg"
  local _pf_cfg_main="${_linux_tkg_dir}/customization.cfg"
  if [[ -f "${_pf_cfg_main}" ]]; then
    local _cv _cno _cc
    _cv=$(__cfg_val '_version' "${_pf_cfg_main}")
    _cno=$(__cfg_val '_nvidia_pkg' "${_pf_cfg_main}")
    _cc=$(__cfg_val '_compiler' "${_pf_cfg_main}")
    [[ -n "${_cv}" ]] && _pf_version="${_cv}"
    [[ -n "${_cno}" ]] && _pf_nvidia="${_cno}"
    [[ -n "${_cc}" ]] && _pf_compiler="${_cc}"
    # ext config wins
    if [[ -f "${_pf_cfg_ext}" ]]; then
      _ev=$(__cfg_val '_version' "${_pf_cfg_ext}")
      _eno=$(__cfg_val '_nvidia_pkg' "${_pf_cfg_ext}")
      _ec=$(__cfg_val '_compiler' "${_pf_cfg_ext}")
      [[ -n "${_ev}" ]] && _pf_version="${_ev}"
      [[ -n "${_eno}" ]] && _pf_nvidia="${_eno}"
      [[ -n "${_ec}" ]] && _pf_compiler="${_ec}"
    fi
  fi

  # prompt for _nvidia_pkg if not set in config
  if [[ -n "${_pf_nvidia}" ]]; then
    if __resolve_nvidia_value "${_pf_nvidia}"; then
      _pf_nvidia="${_resolved_nvidia}"
      _pf_nvidia_variant="${_resolved_nvidia_variant}"
    else
      msgwarning "Ignoring invalid _nvidia_pkg value in config: ${_pf_nvidia}${break}"
      _pf_nvidia=""
    fi
  fi

  if [[ -z "${_pf_nvidia}" ]]; then
    msginfo "${break}${neon}${uline_on}NVIDIA OPEN MODULE${uline_off}:${reset} ${light}Which NVIDIA open driver version for the combined install?${reset}${break}"
    msgplain " Supported kernels: ${gray}6.18  7.0${reset}  │  Requires Turing+ GPU (GTX 16+ or RTX 20xx or newer)"
    msgplain " ${gray}Set${reset} ${gray}_nvidia_pkg${reset} ${gray}in${reset} ${gray}~/.config/frogminer/linux-tkg.cfg${reset} ${gray}to one of the numeric versions below.${reset}${break}"
    msgplain " ${neon}${uline_on}0${uline_off}${reset} │ ${_nvidia_versions[latest]}  ${gray}— default branch, selected${reset} ${neon}(default)${reset}"
    msgplain " ${orange}1${reset} │ ${_nvidia_versions[vulkan]}  ${gray}— Vulkan developer beta${reset}"
    msgplain " ${gray}2${reset} │ ${_nvidia_versions[legacy]}  ${gray}— legacy/LTS branch${reset}"
    msgplain " ${_red}9${reset} │ Cancel${break}"
    __prompt_timer "[${neon}${uline_on}0${uline_off}${reset}/${orange}1${reset}/${gray}2${reset}/${_red}9${reset}]" 60 0
    case "${_user_answer}" in
      1)
        _pf_nvidia="${_nvidia_versions[vulkan]}"
        _pf_nvidia_variant="vulkan"
        ;;
      2)
        _pf_nvidia="${_nvidia_versions[legacy]}"
        _pf_nvidia_variant="legacy"
        ;;
      9)
        msginfo "${break}${orange}Cancelled by user${reset}${break}"
        __exit 1
        ;;
      *)
        _pf_nvidia="${_nvidia_versions[latest]}"
        _pf_nvidia_variant="latest"
        ;;
    esac
    msgplain "${break} Selected: ${gray}${_pf_nvidia}${reset}"
  fi

  # resolve driver version and branch from version map
  local _driver_version_val="${_pf_nvidia}"
  if [[ -z "${_pf_nvidia_variant}" ]]; then
    __resolve_nvidia_value "${_pf_nvidia}"
    _pf_nvidia="${_resolved_nvidia}"
    _pf_nvidia_variant="${_resolved_nvidia_variant}"
    _driver_version_val="${_resolved_nvidia}"
  fi
  local _driver_branch_val=""
  case "${_pf_nvidia_variant}" in
    vulkan) _driver_branch_val="vulkandev" ;;
    *) _driver_branch_val="regular" ;;
  esac

  # linux-tkg makedeps (kernel ≥ 6.12, rust always included)
  local _ltkg_makedeps=(
    'bc' 'bison' 'cpio' 'docbook-xsl' 'flex' 'git' 'graphviz'
    'gettext' 'imagemagick' 'inetutils' 'libelf' 'pahole'
    'patchutils' 'perl' 'python' 'python-sphinx' 'python-sphinx_rtd_theme'
    'rust' 'rust-bindgen' 'rust-src' 'tar' 'wget' 'xmlto' 'xz' 'zstd'
  )
  if [[ "${_pf_compiler}" == "llvm" ]]; then
    _ltkg_makedeps+=('clang' 'llvm' 'lld')
  fi
  msginfo "${break}${neon}${uline_on}MAKEDEPS${uline_off}:${reset} ${light}Checking linux-tkg build dependencies…${reset}"
  __ensure_packages "${_ltkg_makedeps[@]}" || return 1

  # build linux-tkg
  local _linux_tkg_preset="${tkg_tmp_dir}/linux_tkg_preset.cfg"
  mkdir -p "${tkg_tmp_dir}"
  if [[ -f "${_pf_cfg_ext}" ]]; then
    cat "${_pf_cfg_ext}" >"${_linux_tkg_preset}"
    echo >>"${_linux_tkg_preset}"
  else
    : >"${_linux_tkg_preset}"
  fi
  # append chosen values to preset
  [[ -n "${_pf_version}" ]] && printf '_version=%q\n' "${_pf_version}" >>"${_linux_tkg_preset}"
  [[ -n "${_pf_nvidia}" ]] && printf '_nvidia_pkg=%q\n' "${_pf_nvidia}" >>"${_linux_tkg_preset}"

  local _build_command="rm -f BIG_UGLY_FROGMINER && _EXT_CONFIG_PATH=\"${_linux_tkg_preset}\" makepkg -d"
  _tkg_skip_status="1"
  __install_package "${damachine_linux_tkg_repo}" "linux-tkg" "${_build_command}" "" "" "staging"
  local _status=$?
  local _linux_duration="${SECONDS}"

  if [[ ${_status} -ne 0 ]]; then
    msgerror "Linux-TkG build failed — skipping Nvidia-all build.${break}"
    return "${_status}"
  fi

  # nvidia-all makedeps (nvsettings always enabled)
  local _nv_makedeps=('linux-headers' 'patchelf'
    'jansson' 'gtk3' 'libxv' 'libvdpau' 'libxext' 'vulkan-headers')
  msginfo "${break}${neon}${uline_on}MAKEDEPS${uline_off}:${reset} ${light}Checking nvidia-all build dependencies…${reset}"
  __ensure_packages "${_nv_makedeps[@]}" || return 1

  # build nvidia-all
  local _preset_cfg="${tkg_tmp_dir}/nvidia_all/pre-customization.cfg"
  mkdir -p "${tkg_tmp_dir}/nvidia_all"

  cat >"${_preset_cfg}" <<NVIDIA_CUSTOMIZATION_CFG
# nvidia-all preset config — generated by tkginstaller (linux-nvidia combined install)
# Edit values in the __write_nvidia_preset_cfg() heredoc inside tkginstaller to customize.
#
# _EXT_CONFIG_PATH is explicitly cleared so ~/.config/frogminer/nvidia-all.cfg does NOT
# override this file. Remove this line only if you want your personal nvidia-all.cfg applied.
_EXT_CONFIG_PATH="~/.tkg_installer_ignored_config_path/nvidia-all.cfg"
CUSTOM_GCC_PATH=""
_series_in_pkgname=""
_kerneloverride=""
_local_package_storing=""
_build_utils_package_only="true"
_lib32="true"
_opencl="true"
_nvsettings="true"
_libxnvctrl="true"
_eglwayland="external"
_eglgbm="external"
_eglx11="external"
_driver_version="${_driver_version_val}"
_driver_branch="${_driver_branch_val}"
_md5sum="SKIP"
_open_source_modules="false"
_module_signing="false"
_blacklist_nouveau="true"
_modprobe="true"
_modprobe_mobile="true"
_perf_optimizations="true"
_nvidia_patch_enc_fbc="true"
_bsb_dsc_fix="true"
_only_update_if_newer=""
_dkms="false"
_target_kernel=""
_gcc15_fix="false"
_disable_libalpm_hook=""
_gcc14_fix="false"
_54_prime_fixing_attempt="false"
_62142_fix="false"
NVIDIA_CUSTOMIZATION_CFG

  # build only
  _build_command="rm -f options && mv \"${_preset_cfg}\" customization.cfg && makepkg -d"
  _tkg_skip_status="1"
  # shellcheck disable=SC2218
  __install_package "${damachine_nvidia_all_repo}" "nvidia-all" "${_build_command}" "" "" "staging"
  _status=$?
  local _nvidia_duration="${SECONDS}"

  rm -rf "${tkg_tmp_dir}/nvidia_all"

  if [[ ${_status} -ne 0 ]]; then
    msgerror "Nvidia-all build failed — aborting combined install.${break}"
    return "${_status}"
  fi

  # collect all built packages and install at once
  local _all_pkgs=()
  while IFS= read -r -d '' _pkg; do
    _all_pkgs+=("${_pkg}")
  done < <(find "${tkg_tmp_dir}/nvidia-all" -maxdepth 1 -name '*.pkg.tar*' -print0 2>/dev/null)
  while IFS= read -r -d '' _pkg; do
    _all_pkgs+=("${_pkg}")
  done < <(find "${tkg_tmp_dir}/linux-tkg" -maxdepth 1 -name '*.pkg.tar*' -print0 2>/dev/null)

  if [[ ${#_all_pkgs[@]} -eq 0 ]]; then
    msgerror "No built packages found to install.${break}"
    return 1
  fi

  msginfo "${break}${neon}${uline_on}INSTALL${uline_off}:${reset} ${light}Installing ${gray}${#_all_pkgs[@]}${reset}${light} packages via ${gray}pacman -U${reset}${light}:${reset}"
  for _pkg in "${_all_pkgs[@]}"; do
    msgplain "  ${gray}$(basename "${_pkg}")${reset}"
  done
  msgplain "${break}"

  sudo pacman -U "${_all_pkgs[@]}"
  _status=$?

  # remove built packages after installation
  if [[ ${_status} -eq 0 ]]; then
    msgplain "${break}${neon}Cleaning up built packages...${reset}"
    find "${tkg_tmp_dir}/linux-tkg" -maxdepth 1 -name '*.pkg.tar*' -delete 2>/dev/null || true
    find "${tkg_tmp_dir}/nvidia-all" -maxdepth 1 -name '*.pkg.tar*' -delete 2>/dev/null || true
  fi

  # summary
  local _combined_total=$(($(date +%s) - _combined_epoch))
  local _nv_min=$((_nvidia_duration / 60))
  local _nv_sec=$((_nvidia_duration % 60))
  local _lx_min=$((_linux_duration / 60))
  local _lx_sec=$((_linux_duration % 60))
  local _combined_min=$((_combined_total / 60))
  local _combined_sec=$((_combined_total % 60))

  msgorange "${break}Action completed: $(date '+%Y-%m-%d %H:%M:%S')"
  if [[ ${_status} -eq 0 ]]; then
    msginfo "Status: Linux-TkG + Nvidia-all successfully completed!"
  else
    msgerror "Failed process: Linux-TkG + Nvidia-all (Code: ${_status})"
  fi
  msgorange "Duration Linux-TkG build:  ${_lx_min} min ${_lx_sec} sec"
  msgorange "Duration Nvidia-all build: ${_nv_min} min ${_nv_sec} sec"
  msgorange "Combined Duration:         ${_combined_min} min ${_combined_sec} sec"
  return "${_status}"
}

