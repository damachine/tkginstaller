# Generic package installation helper function
__install_package() {
  SECONDS=0
  local _repo_url="$1"
  local _package_name="$2"
  local _build_command="$3"
  local _work_directory="${4:-}"
  local _post_build_hook="${5:-}"
  local _repo_branch="${6:-}"

  __cd_safe "${tkg_tmp_dir}" || return 1

  local _repo_dir
  _repo_dir=$(basename "${_repo_url}" .git)

  # Clone or update repository
  if [[ -d "${_repo_dir}/.git" ]]; then
    msginfo "${break}${neon}${uline_on}PROGRESS${uline_off}:${reset} ${light}Updating ${gray}${_package_name}${reset} ${light}(git pull)...${reset}${break}"
    __cd_safe "${_repo_dir}" || return 1

    local _current_origin=""
    local _current_branch=""
    local _normalized_origin=""
    local _normalized_repo="${_repo_url%.git}"

    _current_origin="$(git remote get-url origin 2>/dev/null || true)"
    _current_branch="$(git branch --show-current 2>/dev/null || true)"
    _normalized_origin="${_current_origin%.git}"
    _normalized_origin="${_normalized_origin%/}"
    _normalized_repo="${_normalized_repo%/}"

    if [[ "${_normalized_origin}" != "${_normalized_repo}" || (-n "${_repo_branch}" && "${_current_branch}" != "${_repo_branch}") ]]; then
      msginfo "${break}${neon}${uline_on}CACHE${uline_off}:${reset} ${light}Selected source changed, cleaning cached ${gray}${_package_name}${reset}${light} checkout...${reset}${break}"
      __cd_safe "${tkg_tmp_dir}" || return 1
      rm -rf "${_repo_dir}"
      __git_clone_retry "${_repo_url}" "" 3 "${_repo_branch}" || {
        msgerror "Cloning failed for: ${_package_name}${break}"
        return 1
      }
      __cd_safe "${tkg_tmp_dir}" || return 1
    else
      if [[ -n "${_repo_branch}" ]]; then
        if ! git pull --ff-only --no-rebase origin "${_repo_branch}"; then
          msginfo "${break}${neon}${uline_on}PROGRESS${uline_off}:${reset} ${light}Git pull failed, trying fresh clone...${reset}${break}"
          __cd_safe "${tkg_tmp_dir}" || return 1
          rm -rf "${_repo_dir}"
          __git_clone_retry "${_repo_url}" "" 3 "${_repo_branch}" || {
            msgerror "Cloning failed for: ${_package_name}${break}"
            return 1
          }
        fi
      elif ! git pull --ff-only --no-rebase; then
        msginfo "${break}${neon}${uline_on}PROGRESS${uline_off}:${reset} ${light}Git pull failed, trying fresh clone...${reset}${break}"
        __cd_safe "${tkg_tmp_dir}" || return 1
        rm -rf "${_repo_dir}"
        __git_clone_retry "${_repo_url}" || {
          msgerror "Cloning failed for: ${_package_name}${break}"
          return 1
        }
      fi
      __cd_safe "${tkg_tmp_dir}" || return 1
    fi
  else
    msginfo "${break}${neon}${uline_on}PROGRESS${uline_off}:${reset} ${light}Cloning ${gray}${_package_name}${reset} ${light}from Frogging-Family repository...${reset}${break}"

    # Handle existing directory without git metadata
    if [[ -d "${_repo_dir}" ]]; then
      # Check for immutable patch files; graft .git if found
      local _has_immutable=false
      if command -v lsattr >/dev/null 2>&1; then
        while IFS= read -r -d '' _chk; do
          if lsattr "${_chk}" 2>/dev/null | cut -d' ' -f1 | grep -qF 'i'; then
            _has_immutable=true
            break
          fi
        done < <(find "${_repo_dir}" -type f \( -name '*.myfrag' -o -name '*.mypatch' \) -print0 2>/dev/null)
      fi

      if [[ "${_has_immutable}" == "true" ]]; then
        # Graft .git from sibling clone; immutable files stay in place
        printf '\033[A          %b\n' "${light}immutable patch files detected — grafting .git...${reset}${break}"
        local _tmp_clone="${_repo_dir}.tkg_clone_$$"
        __git_clone_retry "${_repo_url}" "${_tmp_clone}" 3 "${_repo_branch}" || {
          msgerror "Cloning failed for: ${_package_name}${break}"
          rm -rf "${_tmp_clone}"
          return 1
        }
        mv "${_tmp_clone}/.git" "${_repo_dir}/.git"
        rm -rf "${_tmp_clone}"
        # Restore tracked files; git skips immutable ones
        git -C "${_repo_dir}" checkout -f HEAD 2>/dev/null || true
      else
        msgwarning "Found directory '${_repo_dir}' without git metadata"
        msgprompt "Remove and try fresh clone? [y/N]: "
        __prompt_answer "n"
        [[ "${_user_answer,,}" =~ ^(y|yes)$ ]] && rm -rf "${_repo_dir}" || return 1

        __git_clone_retry "${_repo_url}" "" 3 "${_repo_branch}" || {
          msgerror "Cloning failed for: ${_package_name}${break}"
          return 1
        }
      fi
    else
      __git_clone_retry "${_repo_url}" "" 3 "${_repo_branch}" || {
        msgerror "Cloning failed for: ${_package_name}${break}"
        return 1
      }
    fi
  fi

  __cd_safe "${_repo_dir}" || return 1
  [[ -n "${_work_directory}" ]] && { __cd_safe "${_work_directory}" || return 1; }

  # Display onefetch info
  if command -v onefetch >/dev/null 2>&1; then
    onefetch --no-bold --no-title --no-art --no-color-palette --http-url --email --nerd-fonts --text-colors 15 15 15 15 15 8 2>/dev/null | sed -u 's/^/ /'
    sleep 1.5s
  fi

  # Build and install
  msginfo "${break}${neon}${uline_on}PROGRESS${uline_off}:${reset} ${light}Building ${gray}${_package_name}${reset} ${light}for ${gray}${_distro_name}${reset}${orange}, this may take a while...${reset}${break}"
  eval "${_build_command}"
  local _status=$?

  # Run post-build hook in repo dir (e.g. capture values before PKGBUILD cleanup)
  if [[ -n "${_post_build_hook}" ]]; then
    eval "${_post_build_hook}"
  fi

  if [[ "${_tkg_skip_status:-}" != "1" ]]; then
    __status "${_status}" "${_package_name}"
  fi
  _tkg_skip_status=""
  return "${_status}"
}

# Extract bare value from a config line (last match wins, strips quotes)
__cfg_val() { grep "^${1}=" "${2}" 2>/dev/null | tail -1 | sed "s/^${1}=//;s/'//g;s/\"//g"; }

__resolve_nvidia_value() {
  local _value="${1:-}"

  _resolved_nvidia=""
  _resolved_nvidia_variant=""

  case "${_value}" in
    "" | "false")
      return 0
      ;;
    latest | "${_nvidia_versions[latest]}")
      _resolved_nvidia="${_nvidia_versions[latest]}"
      _resolved_nvidia_variant="latest"
      ;;
    vulkan | "${_nvidia_versions[vulkan]}")
      _resolved_nvidia="${_nvidia_versions[vulkan]}"
      _resolved_nvidia_variant="vulkan"
      ;;
    legacy | "${_nvidia_versions[legacy]}")
      _resolved_nvidia="${_nvidia_versions[legacy]}"
      _resolved_nvidia_variant="legacy"
      ;;
    *)
      return 1
      ;;
  esac

  return 0
}

