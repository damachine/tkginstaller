  msgplain " ${neon}${uline_on}0${uline_off}${reset} │ Upstream       ${gray}${frog_repo_url}/nvidia-all${reset}"
  msgplain " ${orange}1${reset} │ Staging fork   ${gray}https://github.com/damachine/nvidia-all${reset} ${orange}(branch: staging)${reset}${break}"
  __prompt_timer "[${neon}${uline_on}0${uline_off}${reset}/${orange}1${reset}]" 60 0
