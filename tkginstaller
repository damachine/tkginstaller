_compiler="llvm"
_autofdo="true"
_STRIP="false"
AUTOFDO_PRESET_CFG

  if [[ "${_autofdo_pass}" == "pass2" ]]; then
    printf '_autofdo_profile_path="%s"\n' "${_afdo_profile}" >>"${_autofdo_preset}"
  fi

  local _build_command="rm -f BIG_UGLY_FROGMINER && _EXT_CONFIG_PATH=\"${_autofdo_preset}\" makepkg -si"
  __install_package "${_linux_repo}" "linux-tkg" "${_build_command}"
  local _status=$?

  # After Pass 1: show next-steps guide
  if [[ "${_autofdo_pass}" == "pass1" && ${_status} -eq 0 ]]; then
    __msg_info "${_break}${_green_neon}${_uline_on}NEXT STEPS${_uline_off}:${_reset} ${_green_light}After booting the new kernel:${_reset}${_break}"
    __msg_plain " ${_gray}1. Unlock kernel pointers (run as root):${_reset}"
    __msg_plain "    ${_orange}sysctl -w kernel.kptr_restrict=0 kernel.perf_event_paranoid=0${_reset}${_break}"
    __msg_plain " ${_gray}2. Collect perf data — Intel LBR:${_reset}"
    __msg_plain "    ${_orange}perf record -e BR_INST_RETIRED.NEAR_TAKEN:k -a -N -b -c 500009 -o kernel.data -- <workload>${_reset}"
    __msg_plain " ${_gray}   AMD Zen4:${_reset}"
    __msg_plain "    ${_orange}perf record --pfm-events RETIRED_TAKEN_BRANCH_INSTRUCTIONS:k -a -N -b -c 500009 -o kernel.data -- <workload>${_reset}${_break}"
    __msg_plain " ${_gray}3. Convert to .afdo profile:${_reset}"
    __msg_plain "    ${_orange}mkdir -p ~/.config/frogminer${_reset}"
    __msg_plain "    ${_orange}llvm-profgen --kernel --binary=/usr/lib/modules/\$(uname -r)/build/vmlinux \\${_reset}"
    __msg_plain "    ${_orange}  --perfdata=kernel.data -o ~/.config/frogminer/tkg.afdo${_reset}${_break}"
    __msg_plain " ${_gray}4. Rebuild optimized kernel:${_reset} ${_green_neon}$0 linux pass2${_reset}${_break}"
  fi

  return "${_status:-0}"
}

